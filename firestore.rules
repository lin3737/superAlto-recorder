rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /listings/{document} {
      allow read: if true;
      allow write: if false;
    }
    match /cars-data/{document} {
      allow read: if true;
      allow write: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
